@model Lab4_Productos_C36462.Models.Producto

@{
    ViewData["Title"] = "Crear Producto";
}

<h2>Crear Producto</h2>

<div style="max-width: 500px;">
    <form asp-action="Crear" asp-controller="Productos" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="Nombre" class="form-label"></label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Precio" class="form-label"></label>
            <input asp-for="Precio" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="Precio" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Categoria" class="form-label"></label>
            <select asp-for="Categoria" class="form-select">
                <option value="">-- Seleccione --</option>
                <option value="Electrónica">Electrónica</option>
                <option value="Ropa">Ropa</option>
                <option value="Alimentos">Alimentos</option>
                <option value="Hogar">Hogar</option>
                <option value="Deportes">Deportes</option>
            </select>
            <span asp-validation-for="Categoria" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-success">Guardar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}