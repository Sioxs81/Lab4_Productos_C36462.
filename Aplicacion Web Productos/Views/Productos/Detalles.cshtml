@model Lab4_Productos_C36462.Models.Producto

@{
    ViewData["Title"] = "Detalles del Producto";
}

<h2>Detalles del Producto</h2>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Id</dt>
            <dd class="col-sm-8">@Model.Id</dd>

            <dt class="col-sm-4">Nombre</dt>
            <dd class="col-sm-8">@Model.Nombre</dd>

            <dt class="col-sm-4">Precio</dt>
            <dd class="col-sm-8">@Model.Precio.ToString("C")</dd>

            <dt class="col-sm-4">Categoría</dt>
            <dd class="col-sm-8">@Model.Categoria</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>