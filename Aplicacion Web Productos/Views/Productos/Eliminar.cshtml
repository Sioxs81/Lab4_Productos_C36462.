@model Lab4_Productos_C36462.Models.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
}

<h2 class="text-danger">Confirmar Eliminación</h2>
<p>¿Está seguro que desea eliminar el siguiente producto?</p>

<div class="card border-danger" style="max-width: 500px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Id</dt>
            <dd class="col-sm-8">@Model.Id</dd>

            <dt class="col-sm-4">Nombre</dt>
            <dd class="col-sm-8">@Model.Nombre</dd>

            <dt class="col-sm-4">Precio</dt>
            <dd class="col-sm-8">@Model.Precio.ToString("C")</dd>

            <dt class="col-sm-4">Categoría</dt>
            <dd class="col-sm-8">@Model.Categoria</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <form asp-action="Eliminar" asp-controller="Productos" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn btn-danger">Sí, eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>